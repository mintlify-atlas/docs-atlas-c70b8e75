  "keyFeatures": [
    "JWT-based authentication with token persistence",
    "Workspace and project management with role-based access control",
    "Automated SRS documentation generation with real-time preview",
    "Multi-user collaboration with change tracking and approvals",
    "Version control and revision history for documents",
    "Automatic diagram generation (Mermaid) for sequences and ER diagrams",
    "DOCX export for SRS documents",
    "Cross-platform support (Android, iOS, Web, Windows, macOS, Linux)"
  ],
  "publicApiSurface": [
    "POST /auth/login - User authentication",
    "POST /auth/register - User registration",
    "POST /auth/logout - User logout",
    "GET /auth/me - Get current user info",
    "GET /workspaces - List all workspaces",
    "GET /workspaces/:id - Get workspace details",
    "GET /projects - List all projects",
    "GET /projects/:id - Get project details",
    "GET /documents - List all SRS documents",
    "GET /documents/:id - Get document details",
    "GET /documents/:id/revisions - Get document revision history",
    "GET /users - List all users",
    "GET /users/:id - Get user details"
  ]
